{
  "compilerOptions": {
    "checkJs": true,
    "strict": false,
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "moduleDetection": "legacy",
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "allowJs": true,
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": ["js/**/*.js", "tests/**/*.js"],
  "exclude": ["node_modules"]
}
